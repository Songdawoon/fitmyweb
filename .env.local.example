# ── PortOne V2 credentials ──────────────────────────────────────────
# 포트원 콘솔(https://admin.portone.io) → 상점/채널에서 발급.
# 실제 키는 .env.local 에만 넣고 절대 커밋하지 마세요.

# 브라우저 SDK에서 사용 (공개되어도 되는 값)
NEXT_PUBLIC_PORTONE_STORE_ID=store-00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-00000000-0000-0000-0000-000000000000

# 서버 결제 검증용 API 시크릿 (절대 노출 금지)
PORTONE_API_SECRET=your-portone-v2-api-secret
